# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Connection string from MongoDB Atlas
MONGODB_URI=mongodb://localhost:27017/finance-dashboard

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your_super_secret_access_key
JWT_REFRESH_SECRET=your_super_secret_refresh_key
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cookies (Milliseconds) ───────────────────────────────────────────────────
# 15 mins (900000) and 7 days (604800000)
ACCESS_TOKEN_MAX_AGE=900000
REFRESH_TOKEN_MAX_AGE=604800000

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_GLOBAL=100
RATE_LIMIT_MAX_AUTH=20

# ─── Bcrypt ───────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12
RESEND_API_KEY=re_iwVqEAjY_5
